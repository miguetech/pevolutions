---
import Layout from '../layouts/Layout.astro';
import { NavbarWithProvider } from '../components/NavbarWithProvider';
import Hero from '../apps/public/features/home/components/Hero';
import { TopPlayersWithProvider, ServerInfoWithProvider } from '@/shared/components/navigation/SidebarWithProvider';
import { AuthenticatedLoginBoxWithProvider } from '../components/AuthenticatedLoginBoxWithProvider';
import Footer from '@/shared/components/navigation/Footer';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
---

<Layout title="PEvolutions - Pokémon Online Game">
	<NavbarWithProvider client:load lang={lang} />
	
	<main class="max-w-7xl mx-auto px-6 py-12">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
			{/* Right Column: Sidebar (Appears first on mobile) */}
			<aside class="lg:col-span-4 lg:order-2 flex flex-col gap-y-10">
				<div><AuthenticatedLoginBoxWithProvider client:load lang={lang as 'en' | 'es' | 'pt'} /></div>
				<div><TopPlayersWithProvider client:visible lang={lang as 'en' | 'es' | 'pt'} /></div>
				<div><ServerInfoWithProvider client:load lang={lang as 'en' | 'es' | 'pt'} /></div>
			</aside>

			{/* Left Column: Hero/News */}
			<div class="lg:col-span-8 lg:order-1 space-y-8">
				<Hero client:visible lang={lang as 'en' | 'es' | 'pt'} />
			</div>
		</div>
	</main>

	<Footer client:visible lang={lang as 'en' | 'es' | 'pt'} />
</Layout>
