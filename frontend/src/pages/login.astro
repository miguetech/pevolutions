---
import Layout from '../layouts/Layout.astro';
import { LoginFormWithProvider } from '../components/LoginFormWithProvider';
import { NavbarWithProvider } from '../components/NavbarWithProvider';
import { getTranslations } from '@/i18n/utils';

const lang = (Astro.currentLocale || 'en') as 'en' | 'es' | 'pt';
const t = getTranslations(lang);
---

<Layout title={`${t('nav.login')} - PEvolutions`}>
	<NavbarWithProvider lang={lang} client:load />
	<main class="min-h-screen bg-gray-900 text-white flex items-center justify-center p-4 pt-24">
		<div class="w-full max-w-md">
			<div class="bg-gray-800 rounded-lg shadow-xl p-8">
				<h1 class="text-3xl font-bold text-center mb-6">{t('nav.login')}</h1>
				<LoginFormWithProvider client:load />
				<p class="text-center text-gray-400 mt-6">
					{t('auth.no_account')}
					<a href={`/${lang}/register`} class="text-blue-400 hover:text-blue-300 ml-1">{t('auth.register_link')}</a>
				</p>
			</div>
		</div>
	</main>
</Layout>
