---
import Layout from '../layouts/Layout.astro';
import { LoginFormWithProvider } from '../components/LoginFormWithProvider';
---

<Layout title="Login - PEvolutions">
	<main class="min-h-screen bg-gray-900 text-white flex items-center justify-center p-4">
		<div class="w-full max-w-md">
			<div class="bg-gray-800 rounded-lg shadow-xl p-8">
				<h1 class="text-3xl font-bold text-center mb-6">Login</h1>
				<LoginFormWithProvider client:load />
				<p class="text-center text-gray-400 mt-6">
					Don't have an account? 
					<a href="/register" class="text-blue-400 hover:text-blue-300 ml-1">Register</a>
				</p>
			</div>
		</div>
	</main>
</Layout>
